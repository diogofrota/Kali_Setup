# ============================================================================
# KALI SETUP - MODELO DE CHAVES DE API
# ============================================================================
#
# Este arquivo é apenas um modelo público.
# Não coloque credenciais verdadeiras neste arquivo.
#
# O arquivo real deve ficar em:
#
# ~/.config/kali-setup/api-keys.env
#
# Nunca publique o arquivo real no GitHub.
# ============================================================================

# Shodan: busca por ativos expostos na internet. Usado por Shodan CLI, Nuclei,
# scripts próprios e fluxos de reconhecimento. O plano pode ser gratuito,
# limitado, pago ou mudar com o tempo; consulte sempre a documentação oficial.
SHODAN_API_KEY=""

# SecurityTrails: dados de DNS, domínios e histórico. Pode ser usado por
# Subfinder, Amass e automações de OSINT. Consulte a documentação oficial para
# limites, autenticação e planos disponíveis.
SECURITYTRAILS_API_KEY=""

# VirusTotal: reputação, análise de artefatos e enriquecimento de indicadores.
# Pode apoiar OSINT, análise de malware e scripts Python. Limites e planos podem
# mudar; verifique a documentação oficial antes de automatizar.
VIRUSTOTAL_API_KEY=""

# Censys: pesquisa de ativos, certificados e serviços expostos. Algumas
# integrações usam credencial composta no formato ID:SECRET. Consulte a
# documentação oficial antes de preencher.
CENSYS_API_TOKEN=""

# GitHub: Personal Access Token para buscas autenticadas, automações e APIs.
# Use escopo mínimo necessário e prefira tokens com expiração.
GITHUB_TOKEN=""

# GitLab: Personal Access Token para APIs, inventário de repositórios e
# automações. Use escopo mínimo e rotação periódica.
GITLAB_TOKEN=""

# ProjectDiscovery Cloud: token para recursos da plataforma ProjectDiscovery.
# Pode ser usado por ferramentas do ecossistema ProjectDiscovery.
PROJECTDISCOVERY_API_KEY=""

# Hunter: enriquecimento de e-mails e domínios. Pode apoiar OSINT autorizado.
# Consulte limites e disponibilidade na documentação oficial.
HUNTER_API_KEY=""

# BuiltWith: tecnologias usadas por domínios e aplicações. Útil em
# reconhecimento externo e mapeamento de superfície.
BUILTWITH_API_KEY=""

# BinaryEdge: inteligência sobre serviços expostos. Pode ser usado por
# Subfinder e automações de reconhecimento.
BINARYEDGE_API_KEY=""

# FOFA: mecanismo de busca de ativos. Algumas integrações usam credencial
# composta no formato EMAIL:CHAVE.
FOFA_EMAIL=""
FOFA_API_KEY=""

# ZoomEye: busca de ativos expostos. O Subfinder documenta formatos com host
# regional e chave; confirme o formato oficial antes de preencher.
ZOOMEYE_API_KEY=""

# FullHunt: inventário e descoberta de superfície de ataque.
FULLHUNT_API_KEY=""

# Chaos ProjectDiscovery: dados de subdomínios do Chaos. Consulte a
# documentação oficial para requisitos de acesso.
CHAOS_API_KEY=""

# Intelligence X: busca e inteligência OSINT. Algumas integrações esperam
# credencial composta com host e chave; confirme o formato oficial.
INTELX_API_KEY=""

# Spyse: inteligência de internet. Confirme disponibilidade e formato oficial.
SPYSE_API_KEY=""

# URLScan.io: submissão e consulta de análises de URLs. Use com cuidado para
# não expor alvos sensíveis em serviços públicos.
URLSCAN_API_KEY=""

# GreyNoise: contexto sobre IPs e ruído de internet.
GREYNOISE_API_KEY=""

# AbuseIPDB: reputação e denúncias de IPs.
ABUSEIPDB_API_KEY=""

# IPinfo: enriquecimento de IPs, ASN e geolocalização.
IPINFO_TOKEN=""

# WhoisXML API: WHOIS, DNS e enriquecimento de domínios.
WHOISXML_API_KEY=""

# Netlas: busca e inteligência sobre ativos expostos.
NETLAS_API_KEY=""

# LeakIX: descoberta de serviços expostos e possíveis vazamentos.
LEAKIX_API_KEY=""

# Pulsedive: inteligência de ameaças e enriquecimento de indicadores.
PULSEDIVE_API_KEY=""

# ONYPHE: inteligência de internet e serviços expostos.
ONYPHE_API_KEY=""

# 360 Quake: busca de ativos. Algumas integrações usam credencial composta;
# confirme o formato oficial antes de preencher.
QUAKE_API_KEY=""

# PassiveTotal/RiskIQ: inteligência de infraestrutura. Muitas integrações usam
# credencial composta USUARIO:CHAVE.
PASSIVETOTAL_USERNAME=""
PASSIVETOTAL_API_KEY=""
